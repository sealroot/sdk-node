{
  "name": "@aia-protocol/sdk",
  "version": "0.2.0",
  "description": "Official Node.js/TypeScript SDK for the Agent Identity and Capability Protocol (AICP)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["aia", "ai-agent", "identity", "cryptography", "trust"],
  "license": "Apache-2.0",
  "homepage": "https://sealroot.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/aia-protocol/sdk-node"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "js-sha256": "^0.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
